  "keyFeatures": [
    "A* pathfinding with segmented long-distance path calculation",
    "Automatic block breaking and placing during pathfinding",
    "Mining automation with ore scanning and legit mine mode",
    "Schematic building from .schematic or Litematica files",
    "Elytra flight automation through the Nether",
    "World chunk caching with optional disk persistence",
    "Farm automation for harvesting and replanting crops",
    "Entity following and player tracking",
    "Parkour and complex movement support",
    "Integration with Forge, NeoForge, and Fabric mod loaders",
    "Public Java API for embedding in other Minecraft mods",
    "~100 configurable settings via in-game chat or settings.txt"
  ],
